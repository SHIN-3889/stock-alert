name: DART 재무 분석 (매일 새벽)

on:
  workflow_dispatch:
  schedule:
    - cron: '0 22 * * 0-4'  # 매주 월~금 KST 07:00 (UTC 22:00 전날)

permissions:
  contents: write

jobs:
  dart-analysis:
    runs-on: ubuntu-latest
    steps:
      - name: 체크아웃
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: 최신 동기화
        run: git pull origin main

      - name: 파이썬 설치
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: 라이브러리 설치
        run: pip install requests yfinance

      - name: DART 재무 분석 실행
        env:
          DART_API_KEY: ${{ secrets.DART_API_KEY }}
        run: python dart_analysis.py

      - name: sotp_data.json 커밋
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add sotp_data.json
          if git diff --staged --quiet; then
            echo "변경사항 없음"
          else
            git commit -m "auto: DART 재무 분석 업데이트 [skip ci]"
            git pull --rebase origin main
            git push origin main
          fi
